# Program-14
Program 14# Queue implementation using list

queue = []

# Enqueue operation
def enqueue(item):
    queue.append(item)
    print("Inserted:", item)

# Dequeue operation
def dequeue():
    if len(queue) == 0:
        print("Queue is empty")
    else:
        item = queue.pop(0)
        print("Removed:", item)

# Display queue
def display():
    if len(queue) == 0:
        print("Queue is empty")
    else:
        print("Queue elements:", queue)

# Main program
while True:
    print("\n1.Enqueue")
    print("2.Dequeue")
    print("3.Display")
    print("4.Exit")
    
    choice = int(raw_input("Enter your choice: "))
    
    if choice == 1:
        item = raw_input("Enter element: ")
        enqueue(item)
        
    elif choice == 2:
        dequeue()
        
    elif choice == 3:
        display()
        
    elif choice == 4:
        print("Exit")
        break
        
    else:
        print("Invalid choice")
